rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: is the current user an admin?
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: is the current user a client (read-only role)?
    function isClient() {
      return request.auth != null && exists(/databases/$(database)/documents/clients/$(request.auth.uid));
    }

    // Helper: is the current user on Free tier? (Share with all excludes Free users)
    function isFreeTier() {
      return request.auth != null
        && !exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && !exists(/databases/$(database)/documents/wholesalers/$(request.auth.uid))
        && !exists(/databases/$(database)/documents/clients/$(request.auth.uid))
        && (
          !exists(/databases/$(database)/documents/userTiers/$(request.auth.uid))
          || get(/databases/$(database)/documents/userTiers/$(request.auth.uid)).data.tier == 'free'
        );
    }

    // Deals: owner can read/write/delete (except clients are read-only); shared users can read only; admin can read all and update sharedWith.
    // sharedWithAll: excludes Free tier (paid tiers only)
    // Clients: read-only access to shared deals only; cannot create, update, or delete.
    // Other tiers: can only update/delete deals they created (owner).
    match /deals/{dealId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || (resource.data.sharedWithAll == true && !isFreeTier())
        || ('sharedWith' in resource.data && request.auth.uid in resource.data.sharedWith)
        || isAdmin()
      );
      allow create: if request.auth != null && !isClient() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && !isClient() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
    }
    // Saved searches: owner can read/write; shared users can read only; admin can read all and update sharedWith.
    // Clients: read-only; cannot create, update, or delete.
    match /savedSearches/{searchId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid
        || resource.data.sharedWithAll == true
        || ('sharedWith' in resource.data && request.auth.uid in resource.data.sharedWith)
        || isAdmin()
      );
      allow create: if request.auth != null && !isClient() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && !isClient() && (
        resource.data.userId == request.auth.uid
        || isAdmin()
      );
    }
    // App config: all authenticated users can read; only admins can write
    match /appConfig/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    // Admins: any authenticated user can read (to check if they are admin); only admins can write (use Firebase Admin SDK or Console to add first admin)
    match /admins/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Wholesalers: any authenticated user can read (to check role); only admins can write (via API)
    match /wholesalers/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Wholesaler deals: users can CRUD only their own
    match /wholesalerDeals/{dealId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Interest requests: any authenticated user can create; only admins can read/update
    match /interestRequests/{requestId} {
      allow create: if request.auth != null;
      allow read, update: if isAdmin();
      allow delete: if false;
    }
    // User metadata: users can only read/write their own (lastLoginAt, etc.)
    match /userMetadata/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // User profile: users can only read/write their own (firstName, lastName, phoneNumber)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // User favorites: users can only read/write their own favorites
    match /userFavorites/{favId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Investor properties: all authenticated users can read; only admins can write
    match /investorProperties/{propertyId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
    // User tiers: read by owner; write by admin only (via API for subscription/client assignment)
    match /userTiers/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }
    // Clients: read by owner; write by admin only
    match /clients/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if isAdmin();
    }
    // Deal usage: read/write by owner only
    match /dealUsage/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // User config (deal params): read by owner; write by owner (self) or admin (for client params)
    match /userConfig/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && (
        request.auth.uid == userId
        || isAdmin()
      );
    }
    // Processed webhooks: written by server only (Admin SDK bypasses rules)
    match /processedWebhooks/{eventId} {
      allow read, write: if false;
    }
  }
}
