{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/subscription-cancel-period-end",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|src/|@|assets/|node_modules/|logo\\.png|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
