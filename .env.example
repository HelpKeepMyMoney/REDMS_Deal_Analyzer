# Public site URL for SEO (canonical, Open Graph, sitemap, JSON-LD). No trailing slash.
# VITE_SITE_URL=https://your-production-domain.com

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc

VITE_RENTCAST_API_KEY=your-rentcast-api-key

VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Use Functions emulator on localhost (run: firebase emulators:start --only functions)
VITE_USE_FUNCTIONS_EMULATOR=true

# Firebase Admin (server-side, for Vercel API routes only — not exposed to client)
# Get these from Firebase Console → Project Settings → Service Accounts → Generate new key
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Resend (for interest notification emails — used by api/interest/create.js)
# Sign up at https://resend.com — 3,000 emails/month free
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=info@thecpi.network

# Admin notification email — interest requests (favorite, Zoom, etc.) and new user signups are sent here
ADMIN_NOTIFICATION_EMAIL=helpkeepmymoney@gmail.com

# Cron job auth — set a secret; Vercel sends it as Bearer token when invoking cron endpoints
# CRON_SECRET=your-random-secret
